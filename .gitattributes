# Enforce LF line endings for all text files in the repository.
# Prevents CRLF/LF drift between Windows and Linux/macOS contributors.
* text=auto eol=lf

# Force binary files to never be text-converted.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.zip binary
*.gz binary
*.tgz binary
*.nupkg binary
*.snupkg binary
