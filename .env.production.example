# ============================================================
# Planora — Production Environment Template
#
# This is a non-secret template. Copy the keys into your deployment
# secret store or CI/CD environment, then replace every placeholder
# with generated production values. Do not commit real values.
#
# Confirmed code/config references:
# - docker-compose.yml
# - Services/*/Program.cs
# - Planora.ApiGateway/Program.cs
# - BuildingBlocks/.../ConfigurationValidator.cs
# - frontend/next.config.js
# ============================================================

# Runtime environment
ASPNETCORE_ENVIRONMENT=Production
NEXT_PUBLIC_ENVIRONMENT=production

# Public origins
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_API_GATEWAY_URL=https://api.example.com
Frontend__BaseUrl=https://app.example.com
Cors__AllowedOrigins__0=https://app.example.com

# Compose-compatible infrastructure secrets
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<generate-production-postgres-password>
REDIS_PASSWORD=<generate-production-redis-password>
RABBITMQ_USER=planora
RABBITMQ_PASSWORD=<generate-production-rabbitmq-password>
JWT_SECRET=<generate-production-jwt-secret-minimum-32-chars>

# Direct ASP.NET overrides for deployments that do not use docker-compose.yml
JwtSettings__Secret=<same-value-as-JWT_SECRET>
JwtSettings__Issuer=Planora.Auth
JwtSettings__Audience=Planora.Clients

# Direct connection strings for non-Compose production deployments
ConnectionStrings__AuthDatabase=Host=<postgres-host>;Port=5432;Database=planora_auth_db;Username=<user>;Password=<password>;SSL Mode=Require;Trust Server Certificate=false;
ConnectionStrings__TodoDatabase=Host=<postgres-host>;Port=5432;Database=planora_todo;Username=<user>;Password=<password>;SSL Mode=Require;Trust Server Certificate=false;
ConnectionStrings__CategoryDatabase=Host=<postgres-host>;Port=5432;Database=planora_category;Username=<user>;Password=<password>;SSL Mode=Require;Trust Server Certificate=false;
ConnectionStrings__MessagingDatabase=Host=<postgres-host>;Port=5432;Database=planora_messaging;Username=<user>;Password=<password>;SSL Mode=Require;Trust Server Certificate=false;
ConnectionStrings__Redis=<redis-host>:6379,password=<password>,ssl=True,abortConnect=false

# RabbitMQ service credentials for non-Compose deployments
RabbitMq__HostName=<rabbitmq-host>
RabbitMq__UserName=planora
RabbitMq__Password=<generate-production-rabbitmq-password>
RabbitMQ__HostName=<rabbitmq-host>
RabbitMQ__UserName=planora
RabbitMQ__Password=<generate-production-rabbitmq-password>

# Auth email delivery. Use GmailSmtp with a Google App Password or Smtp with another provider.
Email__Provider=GmailSmtp
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__EnableSsl=true
Email__Username=<gmail-or-smtp-username>
Email__Password=<gmail-app-password-or-smtp-password>
Email__FromEmail=<sender-email>
Email__FromName=Planora
Email__TimeoutSeconds=30

# gRPC dependencies used by Todo API
GrpcServices__AuthApi=http://auth-api:80
GrpcServices__CategoryApi=http://category-api:81

# Production diagnostics
INCLUDE_ERROR_DETAIL=false
