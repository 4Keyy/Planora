# deploy/fly/.env.fly  (NEVER COMMIT — gitignored)
# Source of truth for `deploy/fly/set-secrets.ps1`. Copy this file to
# `deploy/fly/.env.fly`, fill in real values, then run the script.
#
# Every key=value on its own line. Lines starting with '#' are ignored.
# Optional double quotes around the value are stripped.
# Empty values are skipped (the script never stages a blank secret).

# ============================================================================
# REQUIRED — every Planora app
# ============================================================================

# JWT signing key. Minimum 32 characters; identical across every service
# and the Gateway. Rotate by setting on every app simultaneously.
#   powershell:  [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
JwtSettings__Secret=

# gRPC inter-service shared key. Minimum 16 characters (32+ recommended).
# Identical across every service.
#   shell:  openssl rand -base64 32
GrpcSettings__ServiceKey=

# Redis connection string. Use the Upstash or Fly Redis URL.
# Example: "rediss://default:<password>@<host>:<port>"
ConnectionStrings__Redis=

# RabbitMQ broker (CloudAMQP works well on the free tier).
RabbitMq__HostName=
RabbitMq__UserName=
RabbitMq__Password=

# ============================================================================
# REQUIRED — per-service database connection strings
# ============================================================================

# Neon (recommended) gives one database per service. Example URL:
# "Host=ep-xxx-pooler.eu-central-1.aws.neon.tech;Database=planora_auth_db;Username=...;Password=...;SSL Mode=Require;Trust Server Certificate=true"
ConnectionStrings__AuthDatabase=
ConnectionStrings__CategoryDatabase=
ConnectionStrings__TodoDatabase=
ConnectionStrings__MessagingDatabase=

# ============================================================================
# OPTIONAL — Observability
# ============================================================================

# Grafana Cloud (or self-hosted) OTLP gRPC endpoint for traces + metrics.
# When unset, the OpenTelemetry pipeline is a silent no-op.
#   Grafana Cloud example:
#     OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-0.grafana.net/otlp
#     OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(tenant:api_token)>
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Grafana Cloud Loki for centralized logs. When unset, the Loki sink is
# a silent no-op. The Login is your Grafana Cloud user id (tenant id),
# the Token is an instance API token with `logs:write` scope.
#   LOKI_URL=https://logs-prod-eu-west-0.grafana.net/loki/api/v1/push
LOKI_URL=
LOKI_USER=
LOKI_TOKEN=

# ============================================================================
# OPTIONAL — Auth API email delivery
# ============================================================================

# Set Email__Provider=GmailSmtp (or another SMTP provider) to send real
# verification / password reset emails. Default is `Log`, which only
# writes to the Auth API log stream.
Email__Provider=Log
Email__Username=
Email__Password=
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__EnableSsl=true
Email__FromEmail=
Email__FromName=Planora

# ============================================================================
# OPTIONAL — Frontend base URL (verification / reset links + CORS)
# ============================================================================

# The fully-qualified public origin of your Next.js frontend. Used by Auth API
# to build verification / password reset URLs.
Frontend__BaseUrl=

# ============================================================================
# OPTIONAL — overrides
# ============================================================================

# By default set-secrets.ps1 injects these to point at Fly's `.internal:443`
# hostnames. Override only if you run Todo or Messaging on a different network.
# GrpcServices__AuthApi=https://planora-auth.internal:443
# GrpcServices__CategoryApi=https://planora-category.internal:443
