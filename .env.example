# ============================================================
# Planora — Environment Configuration Template
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env          (Linux/macOS/WSL)
#   Copy-Item .env.example .env   (PowerShell)
#
# NEVER commit .env to version control — it is listed in .gitignore.
# For production key planning, use .env.production.example plus docs/secrets-management.md.
#
# Required vs Optional:
#   [REQUIRED] — docker-compose / the service WILL FAIL without this
#   [OPTIONAL] — has a working default; override only when needed
# ============================================================


# ------------------------------------------------------------
# Database — PostgreSQL
# Used by: auth-api, todo-api, category-api, messaging-api
# Docker host port: 5433 -> container port: 5432
# ------------------------------------------------------------

# [REQUIRED] PostgreSQL superuser username
POSTGRES_USER=postgres

# [REQUIRED] PostgreSQL superuser password — docker-compose will fail without this
# Bound to 127.0.0.1:5433 only (not exposed on 0.0.0.0)
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=<change-me>

# [OPTIONAL] Default database created on first start
# Individual services create their own databases via EF Core migrations
POSTGRES_DB=planora


# ------------------------------------------------------------
# Security — JWT
# Used by: ALL .NET services + api-gateway (validated locally by each)
#
# Every service reads the secret from the JwtSettings__Secret environment
# variable (docker-compose) or JwtSettings:Secret (appsettings.json).
# All services MUST share the same value, or tokens issued by auth-api
# will be rejected by every other service (silent 401s).
#
# docker-compose injects JwtSettings__Issuer and JwtSettings__Audience with
# the fixed values below. appsettings.json uses the same defaults.
# ------------------------------------------------------------

# [REQUIRED] JWT HMAC-SHA256 signing secret — must be at least 32 characters.
# Generate a strong value:
#   openssl rand -base64 48                               (Linux/macOS/WSL/Git Bash)
#   [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
#                                                         (PowerShell 5+)
JWT_SECRET=<generate-a-strong-secret-minimum-32-chars>

# [REQUIRED] Internal service-to-service gRPC authentication key (min 16 chars).
# Shared by every backend service; each gRPC server validates it on every
# inbound call and gRPC clients attach it to every outbound call.
# Generate: openssl rand -base64 32
GRPC_SERVICE_KEY=<generate-a-strong-random-key>

# [OPTIONAL] Informational defaults. docker-compose currently injects the
# same fixed issuer/audience values through JwtSettings__Issuer/Audience.
JWT_ISSUER=Planora.Auth
JWT_AUDIENCE=Planora.Clients
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7


# ------------------------------------------------------------
# Message Broker — RabbitMQ
# Used by: auth-api, todo-api, category-api, messaging-api, collaboration-api, realtime-api
# Docker host ports: 127.0.0.1:5672 (AMQP), 127.0.0.1:15672 (Management UI → http://localhost:15672)
#
# Every service reads RabbitMQ from the unified RabbitMq__HostName / RabbitMq__UserName /
# RabbitMq__Password keys (the "RabbitMq" config section). docker-compose builds those from the
# RABBITMQ_USER / RABBITMQ_PASSWORD values below; the host is the "rabbitmq" container.
# ------------------------------------------------------------

# [REQUIRED] Consumed by the RabbitMQ container (RABBITMQ_DEFAULT_USER/PASS) and propagated to
# every service container via RabbitMq__UserName / RabbitMq__Password. docker-compose will fail
# without these. Management UI bound to 127.0.0.1:15672 only.
RABBITMQ_USER=<change-me>
RABBITMQ_PASSWORD=<change-me>


# ------------------------------------------------------------
# Cache — Redis
# Used by: auth-api, todo-api, category-api, messaging-api, collaboration-api, realtime-api
# Docker host port: 6379
#
# Docker starts Redis with requirepass enabled. Every service reads Redis from the unified
# ConnectionStrings__Redis key, which docker-compose builds from REDIS_PASSWORD below.
# (The api-gateway uses an in-memory rate limiter and does not connect to Redis.)
# ------------------------------------------------------------

# [REQUIRED] Redis password — docker-compose will fail without this (requirepass enforced)
# Bound to 127.0.0.1:6379 only (not exposed on 0.0.0.0)
# Generate: openssl rand -base64 24
REDIS_PASSWORD=<change-me>


# ------------------------------------------------------------
# Frontend — Next.js (frontend/)
# Default dev port: 3000  (Next.js default; not configurable via env here)
# Build command: npm run dev
# ------------------------------------------------------------

# [OPTIONAL] API Gateway base URL called by the frontend
# Default (set in next.config.js): http://localhost:5132
# For verification links opened from another device on the same Wi-Fi, set this
# to the laptop LAN origin, for example http://192.168.42.15:5132.
NEXT_PUBLIC_API_URL=http://localhost:5132

# [OPTIONAL] Alias used in some frontend env files
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:5132

# [OPTIONAL] Frontend environment label
NEXT_PUBLIC_ENVIRONMENT=development

# [OPTIONAL] Bind address for Next.js dev server
# Set to 0.0.0.0 to expose on the LAN (e.g. to reach it from another device)
HOST=0.0.0.0

# [OPTIONAL] Frontend origin used inside verification/password-reset emails.
# Use localhost when opening links on the same machine. Use the laptop LAN IP
# when opening links from a phone/tablet on the same Wi-Fi.
Frontend__BaseUrl=http://localhost:3000

# [OPTIONAL] Explicit frontend origins for credentialed CORS in local/LAN dev.
# For ASP.NET array overrides, use numbered keys.
Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=http://127.0.0.1:3000
# Cors__AllowedOrigins__2=http://192.168.42.15:3000


# ------------------------------------------------------------
# Email — real verification/password emails through Gmail SMTP
# Used by: auth-api
#
# Free Gmail setup:
# 1. Enable 2-Step Verification on the sending Google account.
# 2. Create a Google App Password for Mail.
# 3. Set Email__Provider=GmailSmtp and put the 16-character app password
#    in Email__Password. Do not use your normal Google account password.
#
# Default Log mode prints email links to auth-api logs and sends no email.
# ------------------------------------------------------------

# [OPTIONAL] Log | GmailSmtp | Smtp
Email__Provider=Log

# [OPTIONAL] Gmail SMTP defaults. Keep these for Gmail.
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__EnableSsl=true
Email__TimeoutSeconds=30

# [OPTIONAL] Required only when Email__Provider=GmailSmtp or Smtp.
# Example:
# Email__Username=your-gmail-address@gmail.com
# Email__Password=your-16-character-google-app-password
Email__Username=
Email__Password=

# [OPTIONAL] If empty, FromEmail falls back to Email__Username.
Email__FromEmail=
Email__FromName=Planora


# ------------------------------------------------------------
# ASP.NET Core Runtime
# Consumed by docker-compose and/or dotnet run
# ------------------------------------------------------------

# [OPTIONAL] Overrides the ASP.NET Core environment name
# Values: Development | Docker | Production
# docker-compose sets this to "Docker" for each container automatically
ASPNETCORE_ENVIRONMENT=Development

# [OPTIONAL] Overrides Kestrel listen URL at runtime
# Only set this if you need to override the Kestrel config in appsettings.json
# Example: ASPNETCORE_URLS=http://+:5132
# ASPNETCORE_URLS=

# [OPTIONAL] Documentation convenience only. Services do not parse this comma
# list directly; ASP.NET config array overrides should use numbered keys
# such as Cors__AllowedOrigins__0, Cors__AllowedOrigins__1, ...
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ------------------------------------------------------------
# Service Port Reference  (documentation — not consumed as env vars)
#
# Service           | Local Port | Docker Host Port | Protocol
# ------------------+------------+------------------+---------------------
# auth-api (HTTP)   | 5030       | 5031             | local gateway targets 5030; Docker maps host 5031 -> container 80
# auth-api (HTTP2)  | 5031       | —                | local HTTP2 endpoint from appsettings.json
# todo-api          | 5100       | 5100             | HTTP
# category-api REST | 5281       | 5281             | HTTP1
# category-api gRPC | 5282       | 5282             | HTTP2 (gRPC)
# messaging-api     | 5058       | 5058             | HTTP
# realtime-api      | 5032       | 5032             | HTTP (SignalR)
# api-gateway       | 5132       | 5132             | HTTP
# frontend          | 3000       | (not in compose) | HTTP
# postgres          | 5432       | 5433             | TCP
# redis             | 6379       | 6379             | TCP
# rabbitmq AMQP     | 5672       | 127.0.0.1:5672   | TCP
# rabbitmq Mgmt UI  | 15672      | 15672            | HTTP
# ------------------------------------------------------------
