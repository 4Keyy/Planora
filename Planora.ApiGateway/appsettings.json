{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Ocelot": "Information"
    }
  },
  "AllowedHosts": "*",
  "Ocelot": {
    "Routes": [],
    "GlobalConfiguration": {}
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=planora-gateway;Username=postgres;Password=postgres",
    "Redis": "127.0.0.1:6379"
  },
  "JwtSettings": {
    "Secret": "",
    "Issuer": "Planora.Auth",
    "Audience": "Planora.Clients",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:3001" ]
  },
  "Redis": {
    "Configuration": "127.0.0.1:6379,abortConnect=false"
  },
  "RabbitMQ": {
    "Host": "127.0.0.1",
    "Port": "5672",
    "User": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "HealthChecksUI": {
    "HealthChecks": [],
    "EvaluationTimeOnSeconds": 10,
    "MinimumSecondsBetweenFailureNotifications": 60
  },
  "Services": {
    "Auth": { "Url": "http://127.0.0.1:5030", "HealthCheck": "/health" },
    "Category": { "Url": "http://127.0.0.1:5281", "HealthCheck": "/health" },
    "Todo": { "Url": "http://127.0.0.1:5100", "HealthCheck": "/health" },
    "Messaging": { "Url": "http://127.0.0.1:5058", "HealthCheck": "/health" },
    "Realtime": { "Url": "http://127.0.0.1:5032", "HealthCheck": "/health" }
  },
  "RateLimiting": {
    "EnableRateLimiting": true,
    "GeneralRules": {
      "EndpointWhitelist": [],
      "ClientWhitelist": [],
      "Period": "1m",
      "Limit": 100
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": "Information",
    "WriteTo": [ { "Name": "Console" } ],
    "Enrich": [ "FromLogContext" ]
  },
  "Kestrel": { "Endpoints": { "Http": { "Url": "http://*:5132" } } }
}
