{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MessagingDatabase": "Host=localhost;Port=5433;Database=planora_messaging;Username=postgres;Password=postgres;Include Error Detail=false;Maximum Pool Size=100;Minimum Pool Size=5;"
  },
  "Redis": {
    "Configuration": "localhost:6379,abortConnect=false"
  },
  "RabbitMq": {
    "HostName": "localhost",
    // Set via env vars: RabbitMq__UserName / RabbitMq__Password
    "UserName": "",
    "Password": "",
    "Port": "5672"
  },
  "GrpcServices": {
    "AuthApi": "http://localhost:5030"
  },
  "Cache": {
    "DefaultExpiration": "00:30:00",
    "ShortExpiration": "00:05:00",
    "LongExpiration": "02:00:00",
    "EnableCompression": true,
    "UseLocalCache": true,
    "LocalCacheSize": 1000
  },
  "JwtSettings": {
    "Secret": "",
    "Issuer": "Planora.Auth",
    "Audience": "Planora.Clients"
  },
  "Serilog": { "Using": [ "Serilog.Sinks.Console" ], "MinimumLevel": "Information", "WriteTo": [ { "Name": "Console" } ], "Enrich": [ "FromLogContext" ] },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:3001" ]
  },
  "Kestrel": { "Endpoints": { "Http": { "Url": "http://*:5058" } } },
  "HealthChecks": {
    "Enabled": true
  },
  "GrpcSettings": {
    // Set via env var: GrpcSettings__ServiceKey
    "ServiceKey": ""
  }
}
