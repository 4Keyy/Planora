{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "",
    "Issuer": "Planora.Auth",
    "Audience": "Planora.Clients"
  },
  "Redis": {
    "Configuration": "redis:6379,abortConnect=false"
  },
  "RabbitMq": {
    "HostName": "rabbitmq",
    // Overridden at runtime by RabbitMq__UserName / RabbitMq__Password env vars from docker-compose
    "UserName": "",
    "Password": "",
    "Port": "5672"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:80"
      }
    }
  }
}
