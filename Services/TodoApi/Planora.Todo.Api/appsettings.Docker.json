{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "TodoDatabase": "Host=postgres;Port=5432;Database=planora_todo;Username=postgres;Password=postgres;",
    "Redis": "redis:6379"
  },
  "JwtSettings": {
    "Secret": "",
    "Issuer": "Planora.Auth",
    "Audience": "Planora.Clients"
  },
  "RabbitMq": {
    "HostName": "rabbitmq",
    // Overridden at runtime by RabbitMq__UserName / RabbitMq__Password env vars from docker-compose
    "UserName": "",
    "Password": "",
    "Port": "5672"
  },
  "GrpcServices": {
    "AuthApi": "http://auth-api:80",
    "CategoryApi": "http://category-api:81"
  },
  "Kestrel": {
    "Endpoints": {
      "Rest": {
        "Url": "http://*:80",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "http://*:81",
        "Protocols": "Http2"
      }
    }
  }
}
